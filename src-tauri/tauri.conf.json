{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "SpecLens",
	"version": "1.1.1",
	"identifier": "com.danielreis.speclens",
	"build": {
		"beforeDevCommand": "pnpm dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "pnpm build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "SpecLens",
				"width": 1280,
				"height": 900,
				"minWidth": 1280,
				"minHeight": 900
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"minimumSystemVersion": "12.0"
		}
	}
}
